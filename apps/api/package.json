    "bullmq": "^5.53.0",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.7.10",
    "ioredis": "^5.7.0",
    "pg": "^8.16.0",
    "pino": "^9.7.0",
    "prom-client": "^15.1.3",
    "zod": "^3.25.7"
  },
  "devDependencies": {
    "@types/bun": "^1.2.13",
    "@types/pg": "^8.15.2",
    "drizzle-kit": "^0.31.1",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.4"
